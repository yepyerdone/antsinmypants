rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getRoom(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data;
    }

    function isHost(roomId) {
      return getRoom(roomId).hostId == request.auth.uid;
    }

    function isValidUser(data) {
      return data.username is string && data.username.size() >= 3 && data.username.size() <= 32
        && data.winsOffline is int && data.gamesOffline is int
        && data.winsOnline is int && data.gamesOnline is int
        && data.totalWins is int;
    }

    // Daily Leaderboard Rules
    match /daily_leaderboard/{date}/players/{userId} {
      allow list: if true;
      allow get: if true;
      allow create: if isOwner(userId) && incoming().wins == 1 && incoming().date == date;
      allow update: if isOwner(userId) && incoming().wins == existing().wins + 1 && incoming().date == date;
    }

    // Classic Molar Madness Top Scores
    match /leaderboard/{entryId} {
      allow list, get: if true;
      allow create: if isSignedIn()
        && incoming().name is string
        && incoming().name.size() >= 1
        && incoming().name.size() <= 15
        && incoming().score is number
        && incoming().score >= 0;
    }

    // Chairs.io Rules
    function getChairsGame(gameId) {
      return get(/databases/$(database)/documents/games/$(gameId)).data;
    }

    function isChairsGameHost(gameId) {
      return isSignedIn() && getChairsGame(gameId).hostId == request.auth.uid;
    }

    function isChairsGameMember(gameId) {
      return isSignedIn() && exists(/databases/$(database)/documents/games/$(gameId)/players/$(request.auth.uid));
    }

    function isValidChairsGame(data) {
      return data.status in ['lobby', 'playing', 'elimination', 'ended']
        && data.hostId is string
        && data.isPublic is bool
        && data.currentRound is int
        && data.timerValue is int
        && (data.timerStartTime == null || data.timerStartTime is number)
        && (data.winnerId == null || data.winnerId is string)
        && (data.lastEliminatedId == null || data.lastEliminatedId is string)
        && data.createdAt is number
        && data.updatedAt is number;
    }

    function isValidChairsPlayer(data, playerId) {
      return data.uid == playerId
        && data.displayName is string
        && data.displayName.size() >= 1
        && data.displayName.size() <= 50
        && data.isEliminated is bool
        && data.isReady is bool
        && (data.chairId == null || data.chairId is string)
        && data.color is string
        && data.joinedAt is number;
    }

    function isValidChair(data) {
      return data.id is string
        && (data.claimedBy == null || data.claimedBy is string)
        && data.angle is number;
    }

    match /games/{gameId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (existing().isPublic == true || existing().status == 'lobby');

      allow create: if isSignedIn()
        && isValidId(gameId)
        && isValidChairsGame(incoming())
        && incoming().hostId == request.auth.uid;

      allow update: if isSignedIn()
        && isValidChairsGame(incoming())
        && incoming().hostId == existing().hostId
        && (
          existing().hostId == request.auth.uid ||
          isChairsGameMember(gameId)
        );

      allow delete: if isChairsGameHost(gameId);

      match /players/{playerId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn()
          && playerId == request.auth.uid
          && isValidChairsPlayer(incoming(), playerId);

        allow update: if isSignedIn()
          && isValidChairsPlayer(incoming(), playerId)
          && incoming().uid == existing().uid
          && incoming().joinedAt == existing().joinedAt
          && (
            playerId == request.auth.uid ||
            isChairsGameHost(gameId)
          );

        allow delete: if playerId == request.auth.uid || isChairsGameHost(gameId);
      }

      match /chairs/{chairId} {
        allow read: if isSignedIn();

        allow create: if isChairsGameHost(gameId) && isValidChair(incoming());
        allow delete: if isChairsGameHost(gameId);
        allow update: if isSignedIn()
          && isValidChair(incoming())
          && (
            isChairsGameHost(gameId) ||
            (
              isChairsGameMember(gameId)
              && getChairsGame(gameId).status == 'playing'
              && existing().claimedBy == null
              && incoming().claimedBy == request.auth.uid
            )
          );
      }
    }

    // User Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());
    }

    // Validation Functions
    function isValidRoom(data) {
      return data.hostId == request.auth.uid 
        && data.status in ['waiting', 'playing', 'finished']
        && data.round is int && data.round >= 1
        && data.keys().hasAll(['status', 'round', 'hostId', 'createdAt']);
    }

    function isValidPlayer(data) {
        return data.userId == request.auth.uid
        && data.status in ['playing', 'standing', 'busted', 'eliminated', 'winner']
        && (!data.keys().hasAny(['name']) || (data.name is string && data.name.size() <= 32))
        && (!data.keys().hasAny(['hand']) || data.hand is list);
    }

    // Room Rules
    match /rooms/{roomId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && existing().status == 'waiting';
      
      allow create: if isSignedIn() 
        && isValidId(roomId)
        && isValidRoom(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isSignedIn() && (
        // Host can update phase, round, status, dealerHand
        (isHost(roomId) && incoming().hostId == existing().hostId) ||
        // Players can potentially trigger state changes if they were the last ones? 
        // Better to restrict most to host.
        false
      );
      
      allow delete: if isHost(roomId);

      // Player Rules (Subcollection)
      match /players/{playerId} {
        allow read: if isSignedIn();
        
        allow create: if isSignedIn()
          && isOwner(playerId)
          && isValidPlayer(incoming())
          && (getRoom(roomId).status == 'waiting');
          
        allow update: if isSignedIn() && (
          // Self-update
          (isOwner(playerId) && isValidPlayer(incoming()) && existing().status != 'eliminated') ||
          // Host can eliminate or set winner
          (isHost(roomId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
        );
        
        allow delete: if isOwner(playerId) || isHost(roomId);
      }
    }
  }
}
