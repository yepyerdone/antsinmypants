rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isRegisteredAccount() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getRoom(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data;
    }

    function isHost(roomId) {
      return getRoom(roomId).hostId == request.auth.uid;
    }

    function isValidUser(data) {
      return data.username is string && data.username.size() >= 3 && data.username.size() <= 32
        && data.winsOffline is int && data.gamesOffline is int
        && data.winsOnline is int && data.gamesOnline is int
        && data.totalWins is int;
    }

    function isValidPublicProfile(data, userId) {
      return data.uid == userId
        && data.username is string
        && data.username.size() >= 3
        && data.username.size() <= 32
        && data.displayName is string
        && data.displayName.size() >= 3
        && data.displayName.size() <= 32
        && data.searchName is string
        && data.searchName.size() >= 3
        && data.searchName.size() <= 32;
    }

    function isValidUsernameClaim(data, claimId) {
      return data.uid == request.auth.uid
        && data.username is string
        && data.username.size() >= 3
        && data.username.size() <= 32
        && data.searchName == claimId
        && data.searchName is string
        && data.searchName.size() >= 3
        && data.searchName.size() <= 32
        && data.updatedAt is timestamp;
    }

    function hasMatchingUsernameClaim(userId, searchName) {
      return getAfter(/databases/$(database)/documents/usernameClaims/$(searchName)).data.uid == userId;
    }

    function isValidFriend(data, friendId) {
      return data.uid == friendId
        && data.displayName is string
        && data.displayName.size() >= 3
        && data.displayName.size() <= 32;
    }

    function isValidFriendNotification(data) {
      return data.type == 'friend_request'
        && data.status in ['pending', 'accepted', 'declined']
        && data.fromUid is string
        && data.fromName is string
        && data.fromName.size() >= 3
        && data.fromName.size() <= 32;
    }

    function isValidSentFriendRequest(data, targetId) {
      return data.toUid == targetId
        && data.toName is string
        && data.toName.size() >= 3
        && data.toName.size() <= 32
        && data.status in ['pending', 'accepted', 'declined'];
    }

    function isValidStatesScore(data) {
      return data.playerName is string
        && data.playerName.size() > 0
        && data.playerName.size() <= 32
        && data.playerId == request.auth.uid
        && data.timeSeconds is number
        && data.timeSeconds > 0
        && data.statesGuessed == 50
        && data.completedAt is timestamp;
    }

    function isValidTachymetryScore(data) {
      return data.userId is string
        && data.userId.size() <= 128
        && data.username is string
        && data.username.size() >= 1
        && data.username.size() <= 32
        && data.score is number
        && data.score >= 0
        && data.updatedAt is timestamp;
    }

    function isValidFunHouseFrenzyScore(data) {
      return data.userId is string
        && data.userId == request.auth.uid
        && data.name is string
        && data.name.size() >= 1
        && data.name.size() <= 32
        && data.score is number
        && data.score > 0
        && data.wave is number
        && data.wave >= 1
        && data.date is string
        && data.date.size() >= 1
        && data.date.size() <= 32
        && data.updatedAt is timestamp;
    }

    function isValidGoodBoyScore(data) {
      return data.userId is string
        && data.userId == request.auth.uid
        && data.username is string
        && data.username.size() >= 1
        && data.username.size() <= 32
        && data.score is number
        && data.score > 0
        && data.updatedAt is timestamp;
    }

    // Daily Leaderboard Rules
    match /daily_leaderboard/{date}/players/{userId} {
      allow list: if true;
      allow get: if true;
      allow create: if isOwner(userId) && incoming().wins == 1 && incoming().date == date;
      allow update: if isOwner(userId) && incoming().wins == existing().wins + 1 && incoming().date == date;
    }

    // Classic Molar Madness Top Scores
    match /leaderboard/{entryId} {
      allow list, get: if true;
      allow create: if isRegisteredAccount()
        && incoming().name is string
        && incoming().name.size() >= 1
        && incoming().name.size() <= 15
        && incoming().score is number
        && incoming().score >= 0;
      allow delete: if false;
    }

    // States Master Leaderboard Rules
    match /states_leaderboard/{entryId} {
      allow list, get: if true;
      allow create: if isRegisteredAccount()
        && isValidId(entryId)
        && isValidStatesScore(incoming())
        && incoming().completedAt == request.time;
      allow delete: if false;
    }

    // Tachymetry Leaderboard Rules
    match /tachymetry_leaderboard/{userId} {
      allow list, get: if true;
      allow create: if isRegisteredAccount()
        && isOwner(userId)
        && isValidId(userId)
        && isValidTachymetryScore(incoming())
        && incoming().userId == request.auth.uid
        && incoming().updatedAt == request.time;
      allow update: if isRegisteredAccount()
        && isOwner(userId)
        && isValidTachymetryScore(incoming())
        && incoming().userId == existing().userId
        && incoming().score >= existing().score
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['score', 'updatedAt', 'username']);
      allow delete: if false;
    }

    // Snake Rush Leaderboard Rules
    match /snake_rush_leaderboard/{entryId} {
      allow list, get: if true;
      allow create: if isRegisteredAccount()
        && incoming().name is string
        && incoming().name.size() >= 1
        && incoming().name.size() <= 16
        && incoming().score is number
        && incoming().score >= 0
        && incoming().gameMode is string;
      allow delete: if false;
    }

    // Mole Mania Leaderboard Rules
    match /scores/{entryId} {
      allow list, get: if true;
      allow create: if isRegisteredAccount()
        && incoming().playerName is string
        && incoming().playerName.size() >= 1
        && incoming().playerName.size() <= 15
        && incoming().score is number
        && incoming().score >= 0
        && incoming().userId == request.auth.uid
        && incoming().timestamp is number;
      allow delete: if false;
    }

    // Space Runner Leaderboard Rules
    match /neon_rush_leaderboard/{entryId} {
      allow list, get: if true;
      allow create: if isRegisteredAccount()
        && incoming().name is string
        && incoming().name.size() >= 1
        && incoming().name.size() <= 16
        && incoming().score is number
        && incoming().score > 0
        && incoming().distance is number
        && incoming().distance >= 0
        && incoming().gems is number
        && incoming().gems >= 0;
      allow delete: if false;
    }

    // The Ascension Leaderboard Rules
    match /the_ascension_scores/{entryId} {
      allow list, get: if true;
      allow create: if isRegisteredAccount()
        && incoming().name is string
        && incoming().name.size() >= 1
        && incoming().name.size() <= 16
        && incoming().score is number
        && incoming().score > 0
        && (!incoming().keys().hasAny(['uid']) || incoming().uid == null || incoming().uid == request.auth.uid);
      allow delete: if false;
    }

    // Fun House Frenzy Leaderboard Rules
    match /fun_house_frenzy_scores/{userId} {
      allow list, get: if true;
      allow create: if isRegisteredAccount()
        && isOwner(userId)
        && isValidId(userId)
        && isValidFunHouseFrenzyScore(incoming())
        && incoming().updatedAt == request.time;
      allow update: if isRegisteredAccount()
        && isOwner(userId)
        && isValidFunHouseFrenzyScore(incoming())
        && incoming().userId == existing().userId
        && incoming().score > existing().score
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'score', 'wave', 'date', 'updatedAt']);
      allow delete: if false;
    }

    // Good Boy Leaderboard Rules
    match /good_boy_leaderboard/{userId} {
      allow list, get: if true;
      allow create: if isRegisteredAccount()
        && isOwner(userId)
        && isValidId(userId)
        && isValidGoodBoyScore(incoming())
        && incoming().updatedAt == request.time;
      allow update: if isRegisteredAccount()
        && isOwner(userId)
        && isValidGoodBoyScore(incoming())
        && incoming().userId == existing().userId
        && incoming().score > existing().score
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['username', 'score', 'updatedAt']);
      allow delete: if false;
    }

    // Linguist per-player progress. Private to the profile owner.
    match /linguist_progress/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && isValidId(userId)
        && incoming().uid == userId
        && incoming().playerName is string
        && incoming().playerName.size() >= 1
        && incoming().playerName.size() <= 32
        && incoming().stats is map
        && incoming().levelResults is map
        && incoming().activeAttempts is map
        && incoming().updatedAt == request.time;
    }

    // The Ascension Game Rules
    match /theAscensionUsers/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId)
        && incoming().uid == userId
        && incoming().username is string
        && incoming().username.size() >= 3
        && incoming().username.size() <= 20
        && incoming().elo is number
        && incoming().rank is string
        && incoming().wins is number
        && incoming().losses is number;
    }

    match /theAscensionMatches/{matchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && incoming().player1Id == request.auth.uid
        && incoming().player1Username is string
        && incoming().player1Elo is number
        && incoming().status == 'searching';
      allow update: if isSignedIn()
        && existing().status in ['searching', 'in_progress', 'finished']
        && incoming().status in ['searching', 'in_progress', 'finished']
        && (
          existing().player1Id == request.auth.uid ||
          existing().player2Id == request.auth.uid ||
          incoming().player2Id == request.auth.uid
        );
    }

    // Chairs.io Rules
    function getChairsGame(gameId) {
      return get(/databases/$(database)/documents/games/$(gameId)).data;
    }

    function isChairsGameHost(gameId) {
      return isSignedIn() && getChairsGame(gameId).hostId == request.auth.uid;
    }

    function isChairsGameMember(gameId) {
      return isSignedIn() && exists(/databases/$(database)/documents/games/$(gameId)/players/$(request.auth.uid));
    }

    function isValidChairsGame(data) {
      return data.status in ['lobby', 'playing', 'elimination', 'ended']
        && data.hostId is string
        && data.isPublic is bool
        && data.currentRound is int
        && (!data.keys().hasAny(['chairCount']) || data.chairCount is int)
        && data.timerValue is int
        && (data.timerStartTime == null || data.timerStartTime is number)
        && (data.winnerId == null || data.winnerId is string)
        && (data.lastEliminatedId == null || data.lastEliminatedId is string)
        && data.createdAt is number
        && data.updatedAt is number;
    }

    function isValidChairsPlayer(data, playerId) {
      return data.uid == playerId
        && data.displayName is string
        && data.displayName.size() >= 1
        && data.displayName.size() <= 50
        && data.isEliminated is bool
        && data.isReady is bool
        && (data.chairId == null || data.chairId is string)
        && data.color is string
        && data.joinedAt is number;
    }

    function isValidChair(data) {
      return data.id is string
        && (data.claimedBy == null || data.claimedBy is string)
        && data.angle is number;
    }

    match /games/{gameId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (existing().isPublic == true || existing().status == 'lobby');

      allow create: if isSignedIn()
        && isValidId(gameId)
        && isValidChairsGame(incoming())
        && incoming().hostId == request.auth.uid;

      allow update: if isSignedIn()
        && isValidChairsGame(incoming())
        && incoming().hostId == existing().hostId
        && (
          existing().hostId == request.auth.uid ||
          isChairsGameMember(gameId)
        );

      allow delete: if isChairsGameHost(gameId);

      match /players/{playerId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn()
          && playerId == request.auth.uid
          && getChairsGame(gameId).status == 'lobby'
          && isValidChairsPlayer(incoming(), playerId);

        allow update: if isSignedIn()
          && isValidChairsPlayer(incoming(), playerId)
          && incoming().uid == existing().uid
          && incoming().joinedAt == existing().joinedAt
          && (
            playerId == request.auth.uid ||
            isChairsGameHost(gameId)
          );

        allow delete: if playerId == request.auth.uid || isChairsGameHost(gameId);
      }

      match /chairs/{chairId} {
        allow read: if isSignedIn();

        allow create: if isChairsGameHost(gameId) && isValidChair(incoming());
        allow delete: if isChairsGameHost(gameId);
        allow update: if isSignedIn()
          && isValidChair(incoming())
          && (
            isChairsGameHost(gameId) ||
            (
              isChairsGameMember(gameId)
              && getChairsGame(gameId).status == 'playing'
              && existing().claimedBy == null
              && incoming().claimedBy == request.auth.uid
            )
          );
      }
    }

    // User Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());

      match /friends/{friendId} {
        allow read: if isOwner(userId);
        allow create, update: if isSignedIn()
          && (request.auth.uid == userId || request.auth.uid == friendId)
          && isValidFriend(incoming(), friendId);
        allow delete: if isOwner(userId);
      }

      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create, update: if isSignedIn()
          && isValidFriendNotification(incoming())
          && (
            request.auth.uid == userId ||
            incoming().fromUid == request.auth.uid
          );
        allow delete: if isOwner(userId);
      }

      match /sentFriendRequests/{targetId} {
        allow read: if isOwner(userId);
        allow create, update: if isSignedIn()
          && (
            request.auth.uid == userId ||
            request.auth.uid == targetId
          )
          && isValidSentFriendRequest(incoming(), targetId);
        allow delete: if isOwner(userId);
      }
    }

    match /publicProfiles/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId)
        && isValidPublicProfile(incoming(), userId)
        && hasMatchingUsernameClaim(userId, incoming().searchName);
    }

    match /usernameClaims/{claimId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn()
        && isValidUsernameClaim(incoming(), claimId);
      allow update: if isSignedIn()
        && existing().uid == request.auth.uid
        && incoming().uid == existing().uid
        && isValidUsernameClaim(incoming(), claimId);
      allow delete: if isSignedIn()
        && existing().uid == request.auth.uid;
    }

    // 8 Ball Arcade Matchmaking Rules
    match /queue/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId)
        && incoming().uid == request.auth.uid
        && incoming().name is string
        && incoming().name.size() >= 1
        && incoming().name.size() <= 32;
      allow delete: if isSignedIn();
    }

    match /matches/{matchId} {
      function isEightBallPlayer(data) {
        return isSignedIn()
          && (
            data.players.white.uid == request.auth.uid ||
            data.players.black.uid == request.auth.uid
          );
      }

      allow read: if isEightBallPlayer(existing());
      allow create: if isEightBallPlayer(incoming())
        && incoming().status == 'playing'
        && incoming().state == 'playing';
      allow update: if isEightBallPlayer(existing())
        && isEightBallPlayer(incoming())
        && incoming().state == existing().state;
    }

    // Reaper's Reckoning Matchmaking Rules
    match /reaper_queue/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId)
        && incoming().uid == request.auth.uid
        && incoming().name is string
        && incoming().name.size() >= 1
        && incoming().name.size() <= 32;
      allow delete: if isSignedIn();
    }

    match /reaper_records/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isOwner(userId)
        && incoming().userId == userId
        && incoming().wins is number
        && incoming().wins >= 0
        && incoming().losses is number
        && incoming().losses >= 0
        && incoming().updatedAt == request.time;
    }

    match /reaper_matches/{matchId} {
      function isReaperPlayer(data) {
        return isSignedIn()
          && (
            data.players.player1.uid == request.auth.uid ||
            data.players.player2.uid == request.auth.uid
          );
      }

      allow read: if isReaperPlayer(existing());
      allow create: if isReaperPlayer(incoming())
        && incoming().status == 'playing';
      allow update: if isReaperPlayer(existing())
        && isReaperPlayer(incoming());

      match /secrets/{userId} {
        function isSecretOwnerInMatch() {
          let matchData = get(/databases/$(database)/documents/reaper_matches/$(matchId)).data;
          return isOwner(userId)
            && (
              matchData.players.player1.uid == userId ||
              matchData.players.player2.uid == userId
            );
        }

        allow get: if isSecretOwnerInMatch();
        allow create, update: if isSecretOwnerInMatch()
          && incoming().ownerUid == userId
          && incoming().hiddenPositions is list
          && incoming().hiddenPositions.size() == 5
          && incoming().victimByDoor is map;
      }
    }

    // Friend Chess Rules
    match /friendChessUsers/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /friendChessLobbies/{lobbyId} {
      function isFriendChessPlayer(data) {
        return isSignedIn() && (request.auth.uid == data.playerW || request.auth.uid == data.playerB);
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().playerW == request.auth.uid;
      allow update: if
        (
          existing().status == 'waiting'
          && incoming().status == 'playing'
          && incoming().playerB == request.auth.uid
          && incoming().playerW == existing().playerW
        ) ||
        (
          isFriendChessPlayer(existing()) && (
            (
              existing().status == 'playing' && (
                (existing().turn == 'w' && request.auth.uid == existing().playerW) ||
                (existing().turn == 'b' && request.auth.uid == existing().playerB)
              )
            ) ||
            incoming().status == 'finished'
          )
        );

      match /moves/{moveId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (
          get(/databases/$(database)/documents/friendChessLobbies/$(lobbyId)).data.playerW == request.auth.uid ||
          get(/databases/$(database)/documents/friendChessLobbies/$(lobbyId)).data.playerB == request.auth.uid
        );
      }
    }

    // Validation Functions
    function isValidRoom(data) {
      return data.hostId == request.auth.uid 
        && data.status in ['waiting', 'playing', 'finished']
        && data.round is int && data.round >= 1
        && data.keys().hasAll(['status', 'round', 'hostId', 'createdAt']);
    }

    function isValidPlayer(data) {
        return data.userId == request.auth.uid
        && data.status in ['playing', 'standing', 'busted', 'eliminated', 'winner']
        && (!data.keys().hasAny(['name']) || (data.name is string && data.name.size() <= 32))
        && (!data.keys().hasAny(['hand']) || data.hand is list);
    }

    // Room Rules
    match /rooms/{roomId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && existing().status == 'waiting';
      
      allow create: if isSignedIn() 
        && isValidId(roomId)
        && isValidRoom(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isSignedIn() && (
        // Host can update phase, round, status, dealerHand
        (isHost(roomId) && incoming().hostId == existing().hostId) ||
        // Players can potentially trigger state changes if they were the last ones? 
        // Better to restrict most to host.
        false
      );
      
      allow delete: if isHost(roomId);

      // Player Rules (Subcollection)
      match /players/{playerId} {
        allow read: if isSignedIn();
        
        allow create: if isSignedIn()
          && isOwner(playerId)
          && isValidPlayer(incoming())
          && (getRoom(roomId).status == 'waiting');
          
        allow update: if isSignedIn() && (
          // Self-update
          (isOwner(playerId) && isValidPlayer(incoming()) && existing().status != 'eliminated') ||
          // Host can eliminate or set winner
          (isHost(roomId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
        );
        
        allow delete: if isOwner(playerId) || isHost(roomId);
      }
    }
  }
}
