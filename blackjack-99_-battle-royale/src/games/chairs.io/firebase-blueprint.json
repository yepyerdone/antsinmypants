{
  "entities": {
    "Game": {
      "title": "Game",
      "description": "Represents a musical chairs game session.",
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["lobby", "playing", "elimination", "ended"],
          "description": "Current status of the game."
        },
        "hostId": {
          "type": "string",
          "description": "UID of the player who created the game."
        },
        "isPublic": {
          "type": "boolean",
          "description": "Whether the game is open to anyone."
        },
        "currentRound": {
          "type": "integer",
          "description": "Current round number (starting from 1)."
        },
        "timerValue": {
          "type": "integer",
          "description": "Current countdown timer in seconds."
        },
        "timerStartTime": {
          "type": "string",
          "format": "date-time",
          "description": "When the current timer phase started."
        },
        "winnerId": {
          "type": "string",
          "description": "UID of the winner (set when game ends)."
        },
        "lastEliminated": {
          "type": "string",
          "description": "UID of the player eliminated in the last round."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["status", "hostId", "isPublic", "currentRound", "createdAt", "updatedAt"]
    },
    "Player": {
      "title": "Player",
      "description": "A player within a game.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "isEliminated": { "type": "boolean" },
        "isReady": { "type": "boolean" },
        "chairId": { "type": "string", "description": "ID of the chair claimed in the current round." },
        "color": { "type": "string", "description": "Avatar color." },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "isEliminated", "joinedAt"]
    },
    "Chair": {
      "title": "Chair",
      "description": "A chair instance in a game round.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "claimedBy": { "type": "string", "description": "UID of the player who claimed this chair." },
        "angle": { "type": "number", "description": "Fixed relative position in the circle." }
      },
      "required": [ "id", "angle" ]
    }
  },
  "firestore": {
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Root game document."
    },
    "/games/{gameId}/players/{playerId}": {
      "schema": "Player",
      "description": "Players in the game."
    },
    "/games/{gameId}/chairs/{chairId}": {
      "schema": "Chair",
      "description": "Chairs available in the current round."
    }
  }
}
