rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper to check if user is a member of the game
    function isGameMember(gameId) {
      return isSignedIn() && exists(/databases/$(database)/documents/games/$(gameId)/players/$(request.auth.uid));
    }

    match /games/{gameId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.isPublic == true || resource.data.status == 'lobby');
      
      function isValidGame(data) {
        return data.status in ['lobby', 'playing', 'elimination', 'ended'] &&
               data.hostId is string &&
               data.isPublic is bool &&
               data.currentRound is int &&
               data.createdAt == request.time &&
               data.updatedAt == request.time;
      }

      allow create: if isSignedIn() && isValidGame(incoming()) && incoming().hostId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        // Host can update game state
        (existing().hostId == request.auth.uid && incoming().updatedAt == request.time) ||
        // Players can update timer or round transitions if everyone is ready (simplified for demo)
        (isGameMember(gameId) && incoming().updatedAt == request.time)
      );

      match /players/{playerId} {
        allow read: if isSignedIn();
        
        function isValidPlayer(data) {
          return data.uid == request.auth.uid &&
                 data.displayName is string && data.displayName.size() <= 50 &&
                 data.isEliminated is bool &&
                 data.joinedAt == request.time;
        }

        allow create: if isSignedIn() && playerId == request.auth.uid && isValidPlayer(incoming());
        allow update: if isSignedIn() && playerId == request.auth.uid && 
          incoming().uid == existing().uid &&
          incoming().joinedAt == existing().joinedAt;
        
        // Host can eliminate players or update ready status
        allow update: if isSignedIn() && get(/databases/$(database)/documents/games/$(gameId)).data.hostId == request.auth.uid;
      }

      match /chairs/{chairId} {
        allow read: if isSignedIn();
        
        // Anyone can claim a chair if it's currently unoccupied and game is in playing state
        allow update: if isSignedIn() && 
          isGameMember(gameId) &&
          get(/databases/$(database)/documents/games/$(gameId)).data.status == 'playing' &&
          existing().claimedBy == null &&
          incoming().claimedBy == request.auth.uid;

        // Host resets chairs for new rounds
        allow write: if isSignedIn() && get(/databases/$(database)/documents/games/$(gameId)).data.hostId == request.auth.uid;
      }
    }
  }
}
