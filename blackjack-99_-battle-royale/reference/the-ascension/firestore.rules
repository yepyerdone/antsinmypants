rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User validation
    function isValidUser(data) {
      let requiredKeys = ['uid', 'username', 'elo', 'rank', 'wins', 'losses', 'createdAt'];
      return data.keys().hasAll(requiredKeys) &&
             data.uid is string &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 20 &&
             data.elo is int &&
             data.rank is string &&
             data.wins is int &&
             data.losses is int &&
             data.createdAt is timestamp &&
             (data.keys().size() >= 7 && data.keys().size() <= 9);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // For leaderboard
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['username', 'elo', 'rank', 'wins', 'losses', 'pslScore', 'isVerified'])
      );
    }

    // Match validation
    function isValidMatch(data) {
      return data.keys().hasAll(['player1Id', 'player2Id', 'status', 'createdAt']) &&
             data.player1Id is string &&
             data.player2Id is string &&
             data.status in ['searching', 'in_progress', 'finished'] &&
             data.createdAt is timestamp;
    }

    match /matches/{matchId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidMatch(incoming());
      allow update: if isSignedIn() && (
        // Allow players in the match to update their scores and status
        (request.auth.uid == existing().player1Id || request.auth.uid == existing().player2Id)
      );
      allow list: if isSignedIn();
    }

    // Queue validation
    match /queue/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
  }
}
