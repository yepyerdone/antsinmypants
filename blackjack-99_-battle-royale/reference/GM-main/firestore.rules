rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /lobbies/{lobbyId} {
      function isPlayer(data) {
        return isSignedIn() && (request.auth.uid == data.playerW || request.auth.uid == data.playerB);
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.playerW == request.auth.uid;
      allow update: if 
        // Action: Joining a lobby (Requires status moving from waiting to playing)
        (
          resource.data.status == 'waiting' && 
          request.resource.data.status == 'playing' && 
          request.resource.data.playerB == request.auth.uid &&
          request.resource.data.playerW == resource.data.playerW
        ) || 
        // Action: Game operations (Requires being one of the players)
        (
          isPlayer(resource.data) && (
            // Making a move (Must be your turn)
            (resource.data.status == 'playing' && (
              (resource.data.turn == 'w' && request.auth.uid == resource.data.playerW) ||
              (resource.data.turn == 'b' && request.auth.uid == resource.data.playerB)
            )) ||
            // Ending the game (Checkmate/Draw)
            (request.resource.data.status == 'finished')
          )
        );

      match /moves/{moveId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (
          get(/databases/$(database)/documents/lobbies/$(lobbyId)).data.playerW == request.auth.uid ||
          get(/databases/$(database)/documents/lobbies/$(lobbyId)).data.playerB == request.auth.uid
        );
      }
    }
  }
}
