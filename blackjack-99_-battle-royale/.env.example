# Gemini / backend (if used)
# GEMINI_API_KEY=

# --- Single Firebase project (entire site: Blackjack, Friend Chess, Molar Madness, etc.) ---
# Optional: if BOTH VITE_FIREBASE_API_KEY and VITE_FIREBASE_PROJECT_ID are set, these override
# firebase-applet-config.json at build time (recommended for Vercel/production).
#
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
#
# Named Firestore database id from Firebase Console (omit or use "(default)" for default DB):
# VITE_FIRESTORE_DATABASE_ID=

# Deprecated — use VITE_FIREBASE_* above (Friend Chess no longer uses a separate project):
# VITE_FRIEND_CHESS_FIREBASE_API_KEY=
# VITE_FRIEND_CHESS_FIREBASE_PROJECT_ID=
