# Main site (existing) — e.g. Gemini / server; blackjack uses firebase-applet-config.json

# --- Friend Chess (optional dedicated Firebase) ---
# If unset, Friend Chess uses the same Firebase app as the main site and stores data only under
# `friendChessLobbies` and `friendChessUsers` (see src/games/friend-chess/firestore.friend-chess.rules).
#
# VITE_FRIEND_CHESS_FIREBASE_API_KEY=
# VITE_FRIEND_CHESS_FIREBASE_AUTH_DOMAIN=
# VITE_FRIEND_CHESS_FIREBASE_PROJECT_ID=
# VITE_FRIEND_CHESS_FIREBASE_APP_ID=
# VITE_FRIEND_CHESS_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FRIEND_CHESS_FIREBASE_STORAGE_BUCKET=
# Optional named Firestore database (omit or "(default)" for default DB):
# VITE_FRIEND_CHESS_FIRESTORE_DATABASE_ID=
